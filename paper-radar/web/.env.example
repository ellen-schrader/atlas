# Copy to .env.local and fill in from your Supabase project (Settings → API).
# The URL and anon/publishable key are safe in the browser; RLS enforces access.
# Never put the service_role / secret key here.
#
# Use EITHER our VITE_* names or the NEXT_PUBLIC_* names Supabase's dashboard
# shows — the app reads both. (Vite requires one of these prefixes; a bare name
# is ignored.)

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY

# ...or, pasted straight from the Supabase dashboard:
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR-PUBLISHABLE-KEY

# Atlas API (the FastAPI service). Defaults to http://127.0.0.1:8000 if unset.
VITE_API_URL=http://127.0.0.1:8000
